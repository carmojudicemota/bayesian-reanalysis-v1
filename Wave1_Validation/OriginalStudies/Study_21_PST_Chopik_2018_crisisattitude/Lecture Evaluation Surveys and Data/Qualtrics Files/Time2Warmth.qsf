:{"Display":"7-very interested"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"QuestionID":"QID57"}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID31","SecondaryAttribute":"How many psychology classes have you taken?","TertiaryAttribute":null,"Payload":{"QuestionText":"How many psychology classes have you taken?","DefaultChoices":false,"DataExportTag":"Q31","QuestionType":"TE","Selector":"SL","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How many psychology classes have you taken?","Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"QuestionID":"QID31"}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID56","SecondaryAttribute":"How surprising were the results of this study?","TertiaryAttribute":null,"Payload":{"QuestionText":"How surprising were the results of this study?","DefaultChoices":false,"DataExportTag":"Q70","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"How surprising were the results of this study?","Choices":{"1":{"Display":"1-not at all surprising"},"2":{"Display":"2"},"3":{"Display":"3"},"4":{"Display":"4"},"5":{"Display":"5"},"6":{"Display":"6"},"7":{"Display":"7-very surprising"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"QuestionID":"QID56"}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID27","SecondaryAttribute":"How would you describe your racial\/ethnic background?","TertiaryAttribute":null,"Payload":{"QuestionText":"How would you describe your racial\/ethnic background?","DefaultChoices":false,"DataExportTag":"Q27","QuestionType":"MC","Selector":"MAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"How would you describe your racial\/ethnic background?","Choices":{"1":{"Display":"White"},"2":{"Display":"Black or African American"},"3":{"Display":"Hispanic or Latino"},"4":{"Display":"Asian"},"5":{"Display":"Native Hawaiian or Other Pacific Islander"},"6":{"Display":"American Indian or Alaskan Native"},"7":{"Display":"Multi-racial","TextEntry":"true"},"8":{"Display":"Other","TextEntry":"true"},"9":{"Display":"Don't Know\/Not Sure"}},"ChoiceOrder":[1,2,3,4,5,6,7,8,9],"Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"QuestionID":"QID27"}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID58","SecondaryAttribute":"How would you rate the quality of the research described on the previous page?","TertiaryAttribute":null,"Payload":{"QuestionText":"How would you rate the quality of the research described on the previous page?","DefaultChoices":false,"DataExportTag":"Q74","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"How would you rate the quality of the research described on the previous page?","Choices":{"1":{"Display":"1-very low quality"},"2":{"Display":"2"},"3":{"Display":"3"},"4":{"Display":"4"},"5":{"Display":"5"},"6":{"Display":"6"},"7":{"Display":"7-very high quality"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"QuestionID":"QID58"}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID48","SecondaryAttribute":"I am interested in pursuing graduate school in psychology.","TertiaryAttribute":null,"Payload":{"QuestionText":"I am interested in pursuing graduate school in psychology.","DefaultChoices":false,"DataExportTag":"Q54","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"I am interested in pursuing graduate school in psychology.","Choices":{"1":{"Display":"strongly disagree"},"2":{"Display":"disagree"},"3":{"Display":"slightly disagree"},"4":{"Display":"neither disagree nor agree"},"5":{"Display":"slightly agree"},"6":{"Display":"agree"},"7":{"Display":"strongly agree"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"QuestionID":"QID48"}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID44","SecondaryAttribute":"I like psychology.","TertiaryAttribute":null,"Payload":{"QuestionText":"I like psychology.","DefaultChoices":false,"DataExportTag":"Q46","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"I like psychology.","Choices":{"1":{"Display":"strongly disagree"},"2":{"Display":"disagree"},"3":{"Display":"slightly disagree"},"4":{"Display":"neither disagree nor agree"},"5":{"Display":"slightly agree"},"6":{"Display":"agree"},"7":{"Display":"strongly agree"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"QuestionID":"QID44"}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID45","SecondaryAttribute":"I think psychological research is similar to research in fields like chemistry, physics, or biology.","TertiaryAttribute":null,"Payload":{"QuestionText":"I think psychological research is similar to research in fields like chemistry, physics, or biology.","DefaultChoices":false,"DataExportTag":"Q48","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionD