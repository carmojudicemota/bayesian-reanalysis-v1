TX","Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"If another group of researchers were to run a study similar to the studies described on the previ...","Choices":{"1":{"Display":"1-very unlikely"},"2":{"Display":"2"},"3":{"Display":"3"},"4":{"Display":"4"},"5":{"Display":"5"},"6":{"Display":"6"},"7":{"Display":"7-very likely"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"QuestionID":"QID55"}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID9","SecondaryAttribute":"It is important for a researcher to disclose all measures and experimental conditions that were i...","TertiaryAttribute":null,"Payload":{"QuestionText":"It is important for a researcher to disclose all measures and experimental conditions that were included in a study.","DefaultChoices":false,"DataExportTag":"Q10","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"It is important for a researcher to disclose all measures and experimental conditions that were i...","Choices":{"1":{"Display":"disagree strongly"},"2":{"Display":"disagree"},"3":{"Display":"disagree slightly"},"4":{"Display":"neither disagree nor agree"},"5":{"Display":"agree slightly"},"6":{"Display":"agree"},"7":{"Display":"agree strongly"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"QuestionID":"QID9"}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID8","SecondaryAttribute":"It is important for a researcher to report all measures and experimental conditions that were inc...","TertiaryAttribute":null,"Payload":{"QuestionText":"It is important for a researcher to report all measures and experimental conditions that were included in a study.","DefaultChoices":false,"DataExportTag":"Q9","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"It is important for a researcher to report all measures and experimental conditions that were inc...","Choices":{"1":{"Display":"disagree strongly"},"2":{"Display":"disagree"},"3":{"Display":"disagree slightly"},"4":{"Display":"neither disagree nor agree"},"5":{"Display":"agree slightly"},"6":{"Display":"agree"},"7":{"Display":"agree strongly"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"QuestionID":"QID8"}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID15","SecondaryAttribute":"Looking at your answer to the previous question, why do you think this way?","TertiaryAttribute":null,"Payload":{"QuestionText":"Looking at your answer to the previous question, why do you think this way?","DefaultChoices":false,"DataExportTag":"Q15","QuestionType":"TE","Selector":"ESTB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Looking at your answer to the previous question, why do you think this way?","Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"QuestionID":"QID15"}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID50","SecondaryAttribute":"On the next page, you will read a media summary of a recently published study. Please read this s...","TertiaryAttribute":null,"Payload":{"QuestionText":"On the next page, you will read a media summary of a recently published study. Please read this summary carefully and answer the questions about your impressions of the article.","DefaultChoices":false,"DataExportTag":"Q58","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"On the next page, you will read a media summary of a recently published study. Please read this s...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"QuestionID":"QID50"}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID59","SecondaryAttribute":"Please choose the third option on the scale below (i.e., #3).","TertiaryAttribute":null,"Payload":{"QuestionText":"Please choose the third option on the scale below (i.e., #3).","DefaultChoices":false,"DataExportTag":"Q76","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"Please choose the third option on the scale below (i.e., #3).","Choices":{"1":{"Display":"1-very low quality"},"2":{"Display":"2"},"3":{"Display":"3"},"4":{"Display":"4"},"5":{"Display":"5"},"6":{"Display":"6"},"7":{"Display":"7-very high quality"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"QuestionID":"QID59"}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID2","SecondaryAttribute":"Please indicate your agreement with the following statements. Please answer each question honestly.","TertiaryAttribute":null,"Payload":{"QuestionText":"Please indicate your agreement with the following statements. Please answer each question honestly.","DefaultChoices":false,"DataExportTag":"Q2","QuestionID":"QID2","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please indicate your agreement with the following statements. Please answer each question honestly.","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[]}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID10","SecondaryAttribute":"Please rate how important you consider each aspect of study designs.","TertiaryAttribute":null,"Payload":{"QuestionText":"Please rate how important you consider each aspect of study designs.","DefaultChoices":false,"DataExportTag":"Q11","QuestionID":"QID10","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please rate how important you consider each aspect of study designs.","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[]}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID5","SecondaryAttribute":"Psychologists do not plan their studies well enough in advance.","TertiaryAttribute":null,"Payload":{"QuestionText":"Psychologists do not plan their studies well enough in advance.","DefaultChoices":false,"DataExportTag":"Q6","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"Psychologists do not plan their studies well enough in advance.","Choices":{"1":{"Display":"disagree strongly"},"2":{"Display":"disagree slightly"},"3":{"Display":"disagree"},"4":{"Display":"neither disagree nor agree"},"5":{"Display":"agree"},"6":{"Display":"agree slightly"},"7":{"Display":"agree strongly"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"QuestionID":"QID5"}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID37","SecondaryAttribute":"Replication of research is only a problem in the field of psychology.","TertiaryAttribute":null,"Payload":{"QuestionText":"Replication of research is only a problem in the field of psychology.","DefaultChoices":false,"DataExportTag":"Q37","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"Replication of research is only a problem in the field of psychology.","Choices":{"1":{"Display":"disagree strongly"},"2":{"Display":"disagree"},"3":{"Display":"disagree slightly"},"4":{"Display":"neither disagree nor agree"},"5":{"Display":"agree slightly"},"6":{"Display":"agree"},"7":{"Display":"agree strongly"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"QuestionID":"QID37"}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID39","SecondaryAttribute":"Researchers who perform replication studies are not qualified to conduct psychological research.","TertiaryAttribute":null,"Payload":{"QuestionText":"Researchers who perform replication studies are not qualified to conduct psychological research.","DefaultChoices":false,"DataExportTag":"Q39","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"Researchers who perform replication studies are not qualified to conduct psychological research.","Choices":{"1":{"Display":"disagree strongly"},"2":{"Display":"disagree"},"3":{"Display":"disagree slightly"},"4":{"Display":"neither disagree nor agree"},"5":{"Display":"agree slightly"},"6":{"Display":"agree"},"7":{"Display":"agree strongly"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"QuestionID":"QID39"}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID40","SecondaryAttribute":"Studies that receive a lot of media attention are often reliable.","TertiaryAttribute":null,"Payload":{"QuestionText":"Studies that receive a lot of media attention are often reliable.","DefaultChoices":false,"DataExportTag":"Q40","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"Studies that receive a lot of media attention are often reliable.","Choices":{"1":{"Display":"disagree strongly"},"2":{"Display":"disagree"},"3":{"Display":"disagree slightly"},"4":{"Display":"neither disagree nor agree"},"5":{"Display":"agree slightly"},"6":{"Display":"agree"},"7":{"Display":"agree strongly"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"QuestionID":"QID40"}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID52","SecondaryAttribute":"Study Links Warm Hands, Warm Heart \u00a0 If you're going out on a date anytime soon, you may find thi..","TertiaryAttribute":null,"Payload":{"QuestionText":"<p><span style=\"font-size:24px;\"><span style=\"font-family: 'Times New Roman', serif;\">Study Links Warm Hands, Warm Heart<\/span><\/span><\/p>\n\n<p>&nbsp;<\/p>\n\n<p><span style=\"font-size:12.0pt;font-family:&quot;Times New Roman&quot;,&quot;serif&quot;\">If you're going out on a date anytime soon, you may find this bit of science news useful: In a carefully controlled experiment, people who held something warm were more likely to perceive someone else as emotionally \"warm\" \u2013 and they were more likely to behave in a friendly, generous way themselves.&nbsp;<\/span><\/p>\n\n<p>&nbsp;<\/p>\n\n<p><span style=\"font-size:12.0pt;font-family:&quot;Times New Roman&quot;,&quot;serif&quot;\">So order the soup, not the salad.<o:p><\/o:p><\/span><\/p>\n\n<p>&nbsp;<\/p>\n\n<p><span style=\"font-size:12.0pt;font-family:&quot;Times New Roman&quot;,&quot;serif&quot;\">The student volunteers didn't realize when the experiment started. They showed up at Yale University's psychology building and met their contact near the elevators. She was holding some textbooks and a cup of coffee.<o:p><\/o:p><\/span><\/p>\n\n<p>&nbsp;<\/p>\n\n<p><span style=\"font-size:12.0pt;font-family:&quot;Times New Roman&quot;,&quot;serif&quot;\">Lawrence Williams, who teaches at the University of Colorado, helped design the experiment while he was a doctoral student at Yale. He published his results in this week's issue of the journal Science. The woman with the coffee was his confederate. She knew what she was supposed to do, but she didn't know why. One by one, she took the students up to the fourth floor in an elevator. As they rode up, the woman asked students, \"in a pretty innocuous way, if they wouldn't mind holding her coffee cup while she wrote down some information,\" Williams explained.&nbsp;<\/span><\/p>\n\n<p>&nbsp;<\/p>\n\n<p><span style=\"font-size:12.0pt;font-family:&quot;Times New Roman&quot;,&quot;serif&quot;\">Of the 41 students that participated in the study, half the students got to hold hot coffee\u037e half got iced coffee. They held the cup for only a few seconds. But that short experience must have changed something in their brains. When they arrived at the fourth floor, they filled out questionnaires. They read a short description of a hypothetical person \u2014 Person A \u2014 and they had to evaluate this stranger's personality.&nbsp;<\/span><\/p>\n\n<p>&nbsp;<\/p>\n\n<p><span style=\"font-size:12.0pt;font-family:&quot;Times New Roman&quot;,&quot;serif&quot;\">In Touch With Emotions<\/span><\/p><p><span style=\"font-size:12.0pt;font-family:&quot;Times New Roman&quot;,&quot;serif&quot;\">He<\/span><span style=\"font-family: 'Times New Roman', serif; font-size: 12pt;\">re's where the coffee's influence became apparent. \"Participants who held the hot coffee cup rated this Person A as more generous, more social, happier, better natured\" than participants who held the iced coffee cup, Williams said. Williams thinks it's no coincidence that we use the same word \u2014 warmth \u2014 to describe both a physical and an emotional experience. Somewhere in the brain, those two sensations are linked, he says. And you can imagine why: Think of a baby held in its mother's arms. The child is experiencing love, affection, comfort.<\/span><\/p>\n\n<p>&nbsp;<\/p>\n\n<p><span style=\"font-size:12.0pt;font-family:&quot;Times New Roman&quot;,&quot;serif&quot;\">\"But you also have, at the same time, an experience with a warm object, in that case a warm human being,\" Williams said.<o:p><\/o:p><\/span><\/p>\n\n<p>&nbsp;<\/p>\n\n<p><span style=\"font-size:12.0pt;font-family:&quot;Times New Roman&quot;,&quot;serif&quot;\">Williams carried out a related experiment with 53 participants to confirm this connection. Some student volunteers were asked to evaluate a hot pad, the kind used to treat injuries. Others held a cold pad.<o:p><\/o:p><\/span><\/p>\n\n<p>&nbsp;<\/p>\n\n<p><span style=\"font-size:12.0pt;font-family:&quot;Times New Roman&quot;,&quot;serif&quot;\">They got to choose a reward for participating. Those rewards \u2014 sometimes a fruit drink, sometimes ice cream \u2014 were described either as something for the volunteers to enjoy themselves or to give as a gift to a friend.<o:p><\/o:p><\/span><\/p>\n\n<p>&nbsp;<\/p>\n\n<p><span style=\"font-size:12.0pt;font-family:&quot;Times New Roman&quot;,&quot;serif&quot;\">Cold Item, Cool Response<o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-size:12.0pt;font-family:&quot;Times New Roman&quot;,&quot;serif&quot;\">\"Participants who held and evaluated the hot pad ... were more likely to choose a gift for a friend,\" Williams said, while those \"who held the cold pad were more likely to choose the gift for themselves.\"<o:p><\/o:p><\/span><\/p>\n\n<p><span style=\"font-size:12.0pt;font-family:&quot;Times New Roman&quot;,&quot;serif&quot;\">Apparently, holding something warm made them feel more generous. If nothing else, said Williams, the experiment demonstrates the tight connection between our minds and bodies.<o:p><\/o:p><\/span><\/p>\n\n<p>&nbsp;<\/p>\n\n<p><span style=\"font-size:12.0pt;font-family:&quot;Times New Roman&quot;,&quot;serif&quot;\">In fact, some scientists think emotions actually start in the body. Andreas Meyer-Lindenberg, director of Germany's Central Institute for Mental Health in the city of Mannheim, notes a controversial theory that fear and happiness start as physical reactions. That signals the brain and allows us to feel the emotion. In this hypothesis, he said, a disembodied head \"wouldn't be able to feel these emotions, because they are signatures that actually come from the body and are registered in the brain.\"&nbsp;<\/span><\/p>\n\n<p>&nbsp;<\/p>\n\n<p><span style=\"font-size:12.0pt;font-family:&quot;Times New Roman&quot;,&quot;serif&quot;\">After he read about this experiment, Meyer Lindenberg says, he made a mental note:&nbsp;<\/span><span style=\"font-family: 'Times New Roman', serif; font-size: 12pt;\">At his institute's next advisory council meeting, everybody gets something hot to drink.<\/span><\/p>","DefaultChoices":false,"DataExportTag":"Q62","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Study Links Warm Hands, Warm Heart \u00a0 If you're going out on a date anytime soon, you may find thi...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"QuestionID":"QID52"}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID4","SecondaryAttribute":"The field of psychology has problems replicating results.","TertiaryAttribute":null,"Payload":{"DataExportTag":"Q5","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"Choices":{"1":{"Display":"disagree strongly"},"2":{"Display":"disagree"},"3":{"Display":"disagree slightly"},"4":{"Display":"neither disagree nor agree"},"5":{"Display":"agree slightly"},"6":{"Display":"agree"},"7":{"Display":"agree strongly"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"Language":[],"QuestionID":"QID4","QuestionText":"The field of psychology has problems replicating results.","QuestionDescription":"The field of psychology has problems replicating results.","GradingData":[],"DefaultChoices":false}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID16","SecondaryAttribute":"The incentive structure in psychological research can undermine the broader goals of science.","TertiaryAttribute":null,"Payload":{"QuestionText":"The incentive structure in psychological research can undermine the broader goals of science.","DefaultChoices":false,"DataExportTag":"Q16","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"The incentive structure in psychological research can undermine the broader goals of science.","Choices":{"1":{"Display":"disagree strongly"},"2":{"Display":"disagree"},"3":{"Display":"disagree slightly"},"4":{"Display":"neither disagree nor agree"},"5":{"Display":"agree slightly"},"6":{"Display":"agree"},"7":{"Display":"agree strongly"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"QuestionID":"QID16"}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID38","SecondaryAttribute":"The results from studies with low statistical power are by definition incorrect.","TertiaryAttribute":null,"Payload":{"QuestionText":"The results from studies with low statistical power are by definition incorrect.","DefaultChoices":false,"DataExportTag":"Q38","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"The results from studies with low statistical power are by definition incorrect.","Choices":{"1":{"Display":"disagree strongly"},"2":{"Display":"disagree"},"3":{"Display":"disagree slightly"},"4":{"Display":"neither disagree nor agree"},"5":{"Display":"agree slightly"},"6":{"Display":"agree"},"7":{"Display":"agree strongly"}},"ChoiceOrder":[1,2,3,4,5,6,7],"Validation":{"Settings":{"ForceResponse":"OFF","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"QuestionID":"QID38"}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID1","SecondaryAttribute":"This week, your instructor gave a lecture on best practices in psychology.\u00a0 On the first few page..","TertiaryAttribute":null,"Payload":{"QuestionText":"This week, your instructor gave a lecture on best practices in psychology.&nbsp;<div><br><\/div><div>On the first few pages, you will be asked to complete a questionnaire that looks very similar to one you completed earlier. You will also be asked to read a media summary of a recently published study and asked questions about it, which you also did in the first survey.<\/div><div><br><\/div><div>After these questions and the media summary, you will be asked about your thoughts about the content of the Best Practices lecture and psychological research in general.<div><br><\/div><div>At the end of the survey, you will be asked to provide your NETID (email address) as proof of your participation.<\/div><\/div>","DefaultChoices":false,"DataExportTag":"Q1","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"This week, your instructor gave a lecture on best practices in psychology.\u00a0 On the first few page...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"QuestionID":"QID1"}},{"SurveyID":"SV_1Opo4nmrQFts3RP","Element":"SQ","PrimaryAttribute":"QID51","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"Q60","QuestionType":"Timing","Selector":"PageTimer","Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Disp